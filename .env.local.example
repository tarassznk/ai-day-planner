# Скопіюй цей файл у .env.local і встав свій ОСОБИСТИЙ ключ Anthropic.
# Отримати: console.anthropic.com -> Settings -> API keys -> Create Key
# .env.local у git НЕ комітиться (див. .gitignore). На Vercel цю ж змінну
# додаєш у Project Settings -> Environment Variables.
ANTHROPIC_API_KEY=sk-ant-...
